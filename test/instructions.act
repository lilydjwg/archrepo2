base_dir: /var/cache/pacman/pkg
# wait for server to start
wait

# x86_64 packages
add: any xorg-xev-1.2.7-1-x86_64.pkg.tar.zst
wait
checky: x86_64/xorg-xev-1.2.7-1-x86_64.pkg.tar.zst
checkp: x86_64 xorg-xev=1.2.7-1

# 'any' package
add: x86_64 wayland-protocols-1.48-1-any.pkg.tar.zst
wait
checky: any/wayland-protocols-1.48-1-any.pkg.tar.zst
checky: i686/wayland-protocols-1.48-1-any.pkg.tar.zst
checky: x86_64/wayland-protocols-1.48-1-any.pkg.tar.zst
checkp: x86_64 wayland-protocols=1.48-1
checkp: i686 wayland-protocols=1.48-1

# update a package
add: any wayland-protocols-1.49-1-any.pkg.tar.zst
wait
checky: any/wayland-protocols-1.49-1-any.pkg.tar.zst
checky: i686/wayland-protocols-1.49-1-any.pkg.tar.zst
checky: x86_64/wayland-protocols-1.49-1-any.pkg.tar.zst
checkp: x86_64 wayland-protocols=1.49-1
checkp: i686 wayland-protocols=1.49-1

# downgrade and remove
add: x86_64 wayland-protocols-1.48-1-any.pkg.tar.zst
remove: any wayland-protocols-1.49-1-any.pkg.tar.zst
wait
checkn: any/wayland-protocols-1.49-1-any.pkg.tar.zst
checkn: i686/wayland-protocols-1.49-1-any.pkg.tar.zst
checkn: x86_64/wayland-protocols-1.49-1-any.pkg.tar.zst
checkp: x86_64 wayland-protocols=1.48-1
checkp: i686 wayland-protocols=1.48-1

# completely remove packages
remove: any wayland-protocols-1.48-1-any.pkg.tar.zst
remove: x86_64 xorg-xev-1.2.7-1-x86_64.pkg.tar.zst
wait
checkn: any/wayland-protocols-1.48-1-any.pkg.tar.zst
checkn: i686/wayland-protocols-1.48-1-any.pkg.tar.zst
checkn: x86_64/wayland-protocols-1.48-1-any.pkg.tar.zst
checkp: x86_64 wayland-protocols=null
checkp: i686 wayland-protocols=null
checkp: any wayland-protocols=null
checkp: i686 xorg-xev=null
checkp: x86_64 xorg-xev=null

# add then, while adding, remove it
# look at the log carefully!
add: x86_64 qt6-webengine-6.11.1-4-x86_64.pkg.tar.zst
racing-wait
remove: x86_64 qt6-webengine-6.11.1-4-x86_64.pkg.tar.zst
wait
checkn: x86_64/qt6-webengine-6.11.1-4-x86_64.pkg.tar.zst
checkp: x86_64 qt6-webengine=null
